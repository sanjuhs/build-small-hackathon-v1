# Copy this file to .env for local runtime settings.
# start.sh loads .env automatically. Do not commit real secrets.

# Primary v3 brain: Modal-hosted MiniCPM-o 4.5.
# This endpoint is the public Modal demo gateway in modal-minicpm-omni/.
TOYBOX_MODAL_OMNI_ACTION=1
TOYBOX_MODAL_OMNI_URL=https://sanjuhs123--minicpm-omni-demo.modal.run
TOYBOX_MODAL_OMNI_MODEL=openbmb/MiniCPM-o-4_5
TOYBOX_MODAL_OMNI_SEND_IMAGE=1
TOYBOX_TRACE_POLICY=0

# Optional PET LLM mode through Ollama's OpenAI-compatible endpoint.
# TOYBOX_LLM_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
# TOYBOX_LLM_MODEL=hf.co/openbmb/MiniCPM5-1B-GGUF:Q4_K_M
# TOYBOX_LLM_NUM_CTX=2048
# TOYBOX_LLM_NUM_PREDICT=180

# Hosted OpenAI-compatible endpoint example. Store real tokens as Space secrets,
# not in source control.
# TOYBOX_LLM_ENDPOINT=https://router.huggingface.co/v1/chat/completions
# TOYBOX_LLM_MODEL=provider-backed/chat-model-id
# TOYBOX_LLM_API_KEY=hf_...
# TOYBOX_LLM_BILL_TO=your-hf-org-or-username

# RunPod serverless OpenAI-compatible endpoint example.
# TOYBOX_LLM_ENDPOINT=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/openai/v1/chat/completions
# TOYBOX_LLM_MODEL=openbmb/MiniCPM5-1B-or-your-served-model-id
# RUNPOD_API_KEY=...

# When an LLM endpoint is configured but unavailable, the default behavior is
# visible asleep/model-off mode. Enable this only for local debugging.
# TOYBOX_ALLOW_HEURISTIC_FALLBACK=1

# Optional visual cortex. MiniCPM-V 4.6 can read the rendered room camera frame
# and return perception/blendshape hints for a separate PET LLM.
# TOYBOX_VISION_ENDPOINT=http://127.0.0.1:11434/api/chat
# TOYBOX_VISION_MODEL=openbmb/minicpm-v4.6
# TOYBOX_VISION_NUM_CTX=4096
# TOYBOX_VISION_NUM_PREDICT=220

# Make MiniCPM-V the direct action brain: one multimodal request receives
# the user's command, compact scene JSON, and pet camera frame, then returns
# PET action JSON. Leave TOYBOX_ALLOW_HEURISTIC_FALLBACK unset/false for the
# real demo so disconnection is visible instead of silently using heuristics.
# TOYBOX_MINICPM_V_ACTION=1

# Hosted vision endpoints use the same OpenAI-compatible shape.
# TOYBOX_VISION_ENDPOINT=https://router.huggingface.co/v1/chat/completions
# TOYBOX_VISION_MODEL=provider-backed/vision-model-id
# TOYBOX_VISION_API_KEY=hf_...
# TOYBOX_VISION_BILL_TO=your-hf-org-or-username

# OpenBMB / ModelBest MiniCPM-V serverless example.
# TOYBOX_VISION_ENDPOINT=https://api.modelbest.cn/v1/chat/completions
# TOYBOX_VISION_MODEL=MiniCPM-V-4.6-Instruct
# TOYBOX_VISION_API_KEY=...
# MINICPM_V_API_KEY=...
# MODELBEST_API_KEY=...

# RunPod/OpenAI-compatible visual cortex example.
# TOYBOX_VISION_ENDPOINT=https://api.runpod.ai/v2/YOUR_VISION_ENDPOINT_ID/openai/v1/chat/completions
# TOYBOX_VISION_MODEL=openbmb/MiniCPM-V-4_6-or-your-served-model-id
# RUNPOD_API_KEY=...

# Trace every pet action for future distillation/fine-tuning.
TOYBOX_TRACE=1
TOYBOX_TRACE_PATH=data/traces/pet-actions.jsonl
