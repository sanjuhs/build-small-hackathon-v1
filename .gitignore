# Local environments and secrets
.env
.env.*
!.env.example
!**/.env.example
.venv/
venv/
env/

# Python/runtime caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node/frontend caches
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor noise
.DS_Store
.idea/
.vscode/
.claude/

# Local app runtime state
.toybox.pid
.toybox-*.pid
.toybox.log
*.log
data/traces/*.jsonl
data/memories/*.jsonl
data/*.sqlite3
data/*.sqlite3-*
output/

# Generated Blender scratch files
*.blend
*.blend1
*.blend2
*.blend@

# Heavy VLA training artifacts. Keep JSON summaries, screenshots, PDFs, and
# compressed proof media in git; keep raw datasets/checkpoints local or on
# external artifact storage.
Fireboy-training-policy-vla/**/*.tgz
Fireboy-training-policy-vla/**/*.jsonl
Fireboy-training-policy-vla/**/*.npz
Fireboy-training-policy-vla/**/*.pt
Fireboy-training-policy-vla/**/*.pth
Fireboy-training-policy-vla/**/*.safetensors
Fireboy-training-policy-vla/**/*.gif
Fireboy-training-policy-vla/runpod-artifacts/runpod_artifacts/**/tmp_*frames/
Fireboy-training-policy-vla/vla-rollouts/**/datasets/**/images/
fireboy-vla-physics/**/*.tgz
fireboy-vla-physics/**/*.jsonl
fireboy-vla-physics/**/*.npz
fireboy-vla-physics/**/*.pt
fireboy-vla-physics/**/*.pth
fireboy-vla-physics/**/*.safetensors

# Runtime artifacts intentionally shipped with the Space so the Modal
# MiniCPM-V VLA router can dispatch into local Toy Room policy proofs.
!Fireboy-training-policy-vla/runpod-artifacts/checkpoints/fireboy_minicpm_vla_skill_param_head/minicpm_vla_skill_param_head.pt
!Fireboy-training-policy-vla/runpod-artifacts/checkpoints/fireboy_minicpm_vla_skill_param_head/fireboy_vla_skill_params_allskill.jsonl
