# Local environments and secrets
.env
.env.*
!.env.example
!**/.env.example
.venv/
venv/
env/

# Python/runtime caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node/frontend caches
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor noise
.DS_Store
.idea/
.vscode/
.claude/

# Local app runtime state
.toybox.pid
.toybox-*.pid
.toybox.log
*.log
data/traces/*.jsonl
data/memories/*.jsonl
data/*.sqlite3
data/*.sqlite3-*
output/

# Generated Blender scratch files
*.blend
*.blend1
*.blend2
*.blend@

# Heavy VLA training artifacts. Keep JSON summaries, screenshots, PDFs, and
# compressed proof media in git; keep raw datasets/checkpoints local or on
# external artifact storage.
